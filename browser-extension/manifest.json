{
  "manifest_version": 3,
  "name": "StreamDock",
  "version": "0.4.1",
  "description": "Находит видео на открытой странице и безопасно сохраняет его через локальное приложение.",
  "minimum_chrome_version": "102",
  "key": "",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "StreamDock - скачать видео со страницы",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
